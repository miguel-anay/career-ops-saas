# PostgreSQL
DATABASE_URL=postgres://app_user:app_pw@localhost:5432/careerops?sslmode=disable

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-min-32-chars

# Google OAuth2 (also consumed by worker/lib/gmail.mjs for the
# refresh_token -> access_token exchange — never log GOOGLE_CLIENT_SECRET
# or any access/refresh token)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# Cloudflare R2 (S3-compatible)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=careerops-pdfs

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Serper (salary data in Block D)
SERPER_API_KEY=

# Web
WEB_ORIGIN=http://localhost:3000

# API server
PORT=8080

# Worker server
WORKER_PORT=3001
